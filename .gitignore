# Dependencies
node_modules/

# Build output
dist/

# Test coverage
coverage/

# Local credentials and env files (never commit secrets)
.env
.env.local
.env.*.local

# Editor and OS noise
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Logs
npm-debug.log*
*.log

